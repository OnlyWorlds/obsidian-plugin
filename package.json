		"@types/uuid": "^10.0.0",
		"esbuild": "0.25.5",
		"eslint": "^9.30.1",
		"eslint-plugin-obsidianmd": "0.1.9",
		"globals": "14.0.0",
		"jiti": "2.6.1",
		"tslib": "2.4.0",
		"typescript": "^5.8.3",
		"typescript-eslint": "8.35.1"
	},
	"dependencies": {
		"@onlyworlds/sdk": "^2.2.2",
